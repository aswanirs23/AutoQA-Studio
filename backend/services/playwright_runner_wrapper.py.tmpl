"""Wrapper script executed in a sandboxed subprocess by playwright_runner.

This file is read as text, formatted with the user's code and base_url, and
written to a temp .py file before being run with `python <tempfile>`.

It MUST print exactly one JSON object to stdout as its last action, of the form:
  {{"status": "passed"|"failed"|"error", "screenshot_b64": "..." or null,
   "error_message": "..." or null, "console_log": "..." or null,
   "duration_ms": <int>}}
"""

import asyncio
import base64
import json
import sys
import time
import traceback

USER_CODE = {user_code!r}
BASE_URL = {base_url!r}
HEADLESS = {headless!r}
STORAGE_STATE = {storage_state!r}


async def _capture_screenshot(page):
    try:
        png = await page.screenshot(type="jpeg", quality=80, full_page=False)
        return base64.b64encode(png).decode("ascii")
    except Exception:
        return None


async def _page_context(page) -> str:
    """Capture URL + title + visible-text snippet so a failed assertion is debuggable."""
    parts: list[str] = []
    try:
        parts.append(f"URL: {{page.url}}")
    except Exception:
        pass
    try:
        title = await page.title()
        if title:
            parts.append(f"Title: {{title}}")
    except Exception:
        pass
    try:
        body_text = await page.locator("body").inner_text(timeout=1000)
        snippet = (body_text or "").strip().replace("\n", " ")[:240]
        if snippet:
            parts.append(f"Page text (first 240 chars): {{snippet}}")
    except Exception:
        pass
    return "\n".join(parts)


async def main():
    from playwright.async_api import async_playwright
    started = time.time()
    console_lines: list[str] = []
    result = {{"status": "error", "screenshot_b64": None, "error_message": None,
              "console_log": "", "duration_ms": 0}}
    try:
        async with async_playwright() as pw:
            browser = await pw.chromium.launch(headless=HEADLESS)
            context = await browser.new_context(
                viewport={{"width": 1280, "height": 720}},
                storage_state=STORAGE_STATE,
            )
            page = await context.new_page()
            page.on("console", lambda msg: console_lines.append(f"[{{msg.type}}] {{msg.text}}"))
            try:
                namespace: dict = {{}}
                exec(USER_CODE, namespace)
                test_fn = namespace.get("test")
                if test_fn is None or not callable(test_fn):
                    result["error_message"] = "Generated code does not define an async test(page, base_url) function."
                else:
                    try:
                        await test_fn(page, BASE_URL)
                        # Give SPAs a moment to settle before we screenshot, so
                        # the success screenshot reflects the final UI state.
                        try:
                            await page.wait_for_load_state("networkidle", timeout=3000)
                        except Exception:
                            pass
                        result["status"] = "passed"
                        result["screenshot_b64"] = await _capture_screenshot(page)
                    except AssertionError as e:
                        result["status"] = "failed"
                        ctx = await _page_context(page)
                        base_msg = str(e) or "Assertion failed"
                        result["error_message"] = base_msg + ("\n\n" + ctx if ctx else "")
                        result["screenshot_b64"] = await _capture_screenshot(page)
                    except Exception as e:
                        result["status"] = "error"
                        ctx = await _page_context(page)
                        base_msg = f"{{type(e).__name__}}: {{e}}"
                        result["error_message"] = base_msg + ("\n\n" + ctx if ctx else "")
                        result["screenshot_b64"] = await _capture_screenshot(page)
            finally:
                await context.close()
                await browser.close()
    except Exception as e:
        result["status"] = "error"
        result["error_message"] = f"Runner crashed: {{type(e).__name__}}: {{e}}\n" + traceback.format_exc()[-500:]
    finally:
        result["duration_ms"] = int((time.time() - started) * 1000)
        result["console_log"] = "\n".join(console_lines[-20:])
        sys.stdout.write(json.dumps(result))
        sys.stdout.flush()


if __name__ == "__main__":
    asyncio.run(main())
