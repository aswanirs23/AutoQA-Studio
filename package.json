{
  "name": "testcase-agent-frontend-build",
  "version": "0.0.0",
  "private": true,
  "description": "Build-time tooling for Tailwind CSS. Not a runtime dependency.",
  "scripts": {
    "build:css": "tailwindcss -i ./frontend/tailwind.css -o ./frontend/styles-tailwind.css --minify",
    "watch:css": "tailwindcss -i ./frontend/tailwind.css -o ./frontend/styles-tailwind.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0"
  }
}
