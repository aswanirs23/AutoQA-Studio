# Copy to `.env` in the project root and fill values. Loaded by pydantic-settings (backend/config.py).
#
# LLM / Figma / Jira API keys: set them in the app Settings UI; they are stored in SQLite.
# The variables below are ignored at runtime for secrets (do not rely on .env for API keys).
#
# --- LLM (optional defaults — models / provider; keys via Settings UI) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Default: openai | anthropic | gemini
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_MODEL=gemini-2.0-flash

# --- Figma / Jira (tokens via Settings UI; entries below ignored for secrets) ---
FIGMA_ACCESS_TOKEN=
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# --- Screenshot / image upload (screenshot_parser plugin) ---
# Uses the same LLM provider as generation; API keys come from Settings (SQLite), not .env.

# --- Database & auth (project persistence) ---
# SQLite file under project root (default: data/testgen.db)
DATABASE_PATH=data/testgen.db
# Local dev: AUTH_DISABLED=true uses a built-in user (no login UI required).
# Production / multi-user: AUTH_DISABLED=false, set JWT_SECRET, register via POST /api/auth/register
AUTH_DISABLED=true
JWT_SECRET=

# --- Deployment ---
# Logging level (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=INFO
# CORS allowed origins. "*" for development only.
# In production, set to your frontend origin(s), comma-separated, e.g.
#   CORS_ORIGINS=https://app.example.com,https://staging.example.com
CORS_ORIGINS=*
